# Порт сервера
PORT=4000

# База данных
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres
DATABASE_NAME=indexall

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# Режим
NODE_ENV=development

# ЮКасса (YuKassa) — получите в личном кабинете https://yookassa.ru/my
YUKASSA_SHOP_ID=your-shop-id
YUKASSA_SECRET_KEY=your-secret-key

# URL фронтенда (для редиректа после оплаты и ссылок в письмах)
FRONTEND_URL=http://localhost:3000

# SMTP для отправки писем (Yandex)
SMTP_USER=your-email@yandex.ru
SMTP_PASS=your-app-password

# Секрет для Telegram бота (произвольная строка)
BOT_SECRET=your-bot-secret-key

# Путь к SQLite-базе Telegram-бота для раздела "Подбор по категориям"
# Локально (разработка):
# BOT_DB_PATH=C:/Users/sotne/Desktop/files — копия/bot_database.db
# На VPS (после деплоя укажите абсолютный путь):
# BOT_DB_PATH=/home/user/bot/bot_database.db
