# ── Database ───────────────────────────────────────────────────
DATABASE_HOST=postgres
DATABASE_PORT=5432
DATABASE_USER=postgres
DATABASE_PASSWORD=CHANGE_ME
DATABASE_NAME=indexall

# ── App ────────────────────────────────────────────────────────
PORT=4000
JWT_SECRET=CHANGE_ME_RANDOM_STRING
JWT_EXPIRES_IN=7d
NODE_ENV=production

# ── URLs (update after SSL setup) ─────────────────────────────
FRONTEND_URL=https://YOUR_DOMAIN
NEXT_PUBLIC_API_URL=https://YOUR_DOMAIN/api

# ── Email (Yandex SMTP) ───────────────────────────────────────
SMTP_USER=
SMTP_PASS=

# ── YooKassa ──────────────────────────────────────────────────
YUKASSA_SHOP_ID=
YUKASSA_SECRET_KEY=

# ── Optional ──────────────────────────────────────────────────
BOT_SECRET=
ETM_LOGIN=
ETM_PASSWORD=
